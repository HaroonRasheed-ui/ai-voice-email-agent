    {
      "parameters": {
        "jsCode": "let recipient = null;\nlet transcription = null;\n\n// Step 1: Get recipient from Gemini/AI output\nfor (const item of items) {\n  if (item.json.output && typeof item.json.output === \"string\") {\n    try {\n      const parsed = JSON.parse(item.json.output.replace(/```json|```/g, \"\").trim());\n      if (parsed.recipient) {\n        recipient = parsed.recipient.trim();\n      }\n    } catch (e) {\n      // ignore parsing errors\n    }\n  }\n}\n\n// Step 2: Get transcription text\nfor (const item of items) {\n  if (item.json.content && item.json.content.parts) {\n    transcription = item.json.content.parts[0].text.trim();\n  }\n}\n\n// Step 3: Match recipient with sheet rows (first try exact, then fallback to first word)\nlet email = null;\nif (recipient) {\n  const recipientLower = recipient.toLowerCase();\n  const firstWord = recipientLower.split(\" \")[0]; // get first part of name\n\n  for (const item of items) {\n    if (item.json.Name && item.json.Email) {\n      const nameLower = item.json.Name.toLowerCase();\n\n      // Exact match first\n      if (nameLower === recipientLower) {\n        email = item.json.Email;\n        break;\n      }\n\n      // Fallback: match by first word\n      if (!email && nameLower.startsWith(firstWord)) {\n        email = item.json.Email;\n        break;\n      }\n    }\n  }\n}\n\n// Step 4: Return combined output\nreturn [\n  {\n    json: {\n      recipient,\n      email,\n      text: transcription\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1904,
        -160
      ],
      "id": "ae2cc1e7-0cbf-488f-ab52-c2ef0976d78c",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.text || \"\";\nconst email = $json.email || \"\";\n\n// Build a generic prompt for Gemini\nconst prompt = `\nYou are a helpful assistant.\n\nUser said: \"${text}\"\n\nYour job:\n1. Understand what the user is asking.\n2. If it's a generic request like \"send a message\", create a short, natural, friendly greeting message.\n3. If it's a specific request (e.g., weather report, cover letter, reminder, update), generate a clear and human-like message body that matches exactly what was asked.\n4. Do not include recipient names or email addresses in the message body.\n5. Return only the message text, nothing else.\n`.trim();\n\nreturn [\n  {\n    json: {\n      email,\n      prompt\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
