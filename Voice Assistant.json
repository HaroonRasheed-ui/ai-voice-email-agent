    {
      "parameters": {
        "jsCode": "// Input text from transcription\nconst text = $json.content?.parts?.[0]?.text || \"\";\n\n// Strong and generic prompt\nconst prompt = `\nExtract only the recipient’s full name from the text below.\nIf the name looks misspelled, correct it to the most likely real name.\nDo not invent names that are not present in the text.\nReturn ONLY valid JSON with a single key \"recipient\". No extra text.\n\nText: \"${text}\"\n`;\n\nreturn [\n  {\n    json: {\n      prompt\n    }\n  }\n];\n"
      },
